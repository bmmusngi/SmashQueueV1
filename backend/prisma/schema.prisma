generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id // YYYYMMDDXXXXXX
  status    String   @default("ACTIVE") // ACTIVE, COMPLETED
  createdAt DateTime @default(now())
  players   Player[]
  games     Game[]
}

model Player {
  id            String   @id @default(uuid())
  sessionId     String
  session       Session  @relation(fields: [sessionId], references: [id])
  name          String
  levelWeight   Int
  gender        String
  status        String   @default("ACTIVE") // ACTIVE, RESTING
  paymentStatus String   @default("UNPAID") // UNPAID, PAID
  paymentMode   String?  // GCash, Cash, QRPH
  createdAt     DateTime @default(now())

  // Relations for games (many-to-many)
  gamesAsTeamA  Game[]   @relation("TeamA")
  gamesAsTeamB  Game[]   @relation("TeamB")
}

model Game {
  id           String   @id @default(uuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id])
  type         String   // SINGLES, DOUBLES
  status       String   @default("PENDING") // PENDING, ACTIVE, COMPLETED
  courtId      String?
  startedAt    DateTime?
  endedAt      DateTime?
  shuttlesUsed Int      @default(0)
  winner       String?  // Team A, Team B

  teamA        Player[] @relation("TeamA")
  teamB        Player[] @relation("TeamB")
  createdAt    DateTime @default(now())
}
