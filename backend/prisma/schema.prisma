generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// GLOBAL ROSTER
model Member {
  id          String   @id @default(uuid())
  name        String
  levelWeight Int      @default(3)
  gender      String   @default("M")
  wins        Int      @default(0)
  losses      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  players     Player[]
}

// SESSION ATTENDANCE
model Player {
  id            String   @id @default(uuid())
  name          String
  levelWeight   Int      @default(3)
  gender        String   @default("M")
  
  sessionId     String
  session       Session  @relation(fields: [sessionId], references: [id])

  // Optional link to Member (for guests)
  memberId      String?  
  member        Member?  @relation(fields: [memberId], references: [id])

  status        String   @default("ACTIVE")
  paymentStatus String   @default("UNPAID")
  
  teamA_games   Game[]   @relation("TeamA")
  teamB_games   Game[]   @relation("TeamB")

  createdAt     DateTime @default(now())
}

// MATCHES
model Game {
  id            String    @id @default(uuid())
  sessionId     String
  session       Session   @relation(fields: [sessionId], references: [id])
  
  // NOTE: Reverted to string courtId to avoid model dependency
  courtId       String?   

  type          String    @default("DOUBLES")
  status        String    @default("PENDING")
  winner        String?   
  shuttlesUsed  Int       @default(0)
  
  teamA         Player[]  @relation("TeamA")
  teamB         Player[]  @relation("TeamB")
  
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())
}

// QUEUING SESSIONS
model Session {
  id          String    @id @default(uuid())
  date        DateTime  @default(now())
  status      String    @default("ACTIVE")
  players     Player[]
  games       Game[]
}
