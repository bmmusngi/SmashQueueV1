generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id // YYYYMMDDXXXXXX
  status    String   @default("ACTIVE") // ACTIVE, COMPLETED
  createdAt DateTime @default(now())
  players   Player[]
  games     Game[]
}

model Member {
  id            String   @id @default(uuid())
  name          String
  levelWeight   Int
  gender        String
  wins          Int      @default(0)
  losses        Int      @default(0)
  ties          Int      @default(0)
  createdAt     DateTime @default(now())
  isActive      Boolean  @default(true)
  
  // A member can appear in many sessions as a 'Player'
  sessionEntries Player[]
}

model Player {
  id            String   @id @default(uuid())
  sessionId     String
  session       Session  @relation(fields: [sessionId], references: [id])
  
  // Link to Member (Nullable because walk-ins aren't members)
  memberId      String?
  member        Member?  @relation(fields: [memberId], references: [id])

  name          String
  levelWeight   Int
  gender        String
  status        String   @default("ACTIVE")
  paymentStatus String   @default("UNPAID")
  paymentMode   String?  // GCash, Cash, QRPH
  
  createdAt     DateTime @default(now())

  gamesAsTeamA  Game[]   @relation("TeamA")
  gamesAsTeamB  Game[]   @relation("TeamB")
}

model Game {
  id           String   @id @default(uuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id])
  type         String   // SINGLES, DOUBLES
  status       String   @default("PENDING") // PENDING, ACTIVE, COMPLETED
  courtId      String?
  startedAt    DateTime?
  endedAt      DateTime?
  shuttlesUsed Int      @default(0)
  winner       String?  // Team A, Team B

  teamA        Player[] @relation("TeamA")
  teamB        Player[] @relation("TeamB")
  createdAt    DateTime @default(now())
}
